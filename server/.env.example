# Landlink relay configuration. All values have production-safe defaults;
# override as needed. Copy to `.env` (compose) or /etc/landlink-relay.env (systemd).

# Address to bind the WS/HTTP server (browser/native accounts). Host/systemd:
# keep loopback (Caddy/nginx terminates TLS in front). Docker: 0.0.0.0:8080.
RELAY_BIND=127.0.0.1:8080

# Raw-TCP listener for constrained DEVICES (ESP32) that can't afford TLS. The
# device frames are already E2E-encrypted (AES-256-GCM), so this link needs no
# TLS. Expose this port to devices (open the firewall / a dedicated port). The
# account link stays on RELAY_BIND (wss/443).
RELAY_TCP_BIND=0.0.0.0:9000

# SQLite database path (holds enrollments only). A sibling <path>.secret file
# stores the auto-generated challenge key unless RELAY_CHALLENGE_SECRET is set.
RELAY_DB_PATH=relay.db

# 32-byte base64url HMAC key for enroll challenges. Leave empty to auto-generate
# and persist. Pin it (and share it across instances) with:
#   openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
RELAY_CHALLENGE_SECRET=

# Comma-separated allowed browser Origins (defense-in-depth; not the auth
# boundary). Empty = allow any (fine for self-host; set explicitly in prod).
# e.g. https://landlink.sh,capacitor://localhost,http://localhost:5173
RELAY_ALLOWED_ORIGINS=

# --- limits (safe defaults; tune for your host) ---
# Max concurrent connections. This is MEMORY-bound, not a free ceiling: budget
# ~15k-40k connections per GB of RAM. The 100000 default suits a large host;
# lower it on small boxes and pair it with a container mem_limit / systemd
# MemoryMax so a flood OOMs the service, not the host.
# RELAY_MAX_CONNECTIONS=100000
# RELAY_MAX_PREAUTH_CONNECTIONS=2000
# RELAY_MAX_CONNS_PER_ACCOUNT=8
# RELAY_MAX_DEVICES_PER_ACCOUNT=64
# RELAY_GLOBAL_ENROLLMENT_CAP=5000000
# RELAY_HTTP_RATE_PER_MIN=30
# RELAY_WS_CONNECT_RATE_PER_MIN=120
# RELAY_INBOUND_FRAME_RATE_PER_SEC=50
# RELAY_MAX_MESSAGE_BYTES=4096
# RELAY_MAX_BODY_BYTES=4096

# Logging (tracing env-filter).
# RUST_LOG=info
