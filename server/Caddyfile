# TLS-terminating reverse proxy for the Landlink relay.
#
# Caddy auto-provisions and renews HTTPS certs and proxies WebSockets
# transparently. Replace the domain with yours. Caddy MUST be the sole edge
# proxy: it appends the real client IP to X-Forwarded-For, and the relay trusts
# only the rightmost (Caddy-observed) entry for rate limiting.

relay.example.com {
	# Keep /metrics off the public internet by default — it exposes connection,
	# enrollment, and auth-failure counts. Scrape it locally on 127.0.0.1:8080
	# instead. Remove this handle only if you front /metrics with its own auth.
	@metrics path /metrics
	handle @metrics {
		respond 403
	}

	# Everything else: proxy to the relay.
	# Host/systemd deploy: relay on loopback. For docker-compose, use `relay:8080`.
	handle {
		reverse_proxy 127.0.0.1:8080
	}
}
